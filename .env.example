# Copy this file to .env.local and fill in the values from your Supabase project.
# .env.local is gitignored — real keys never get committed or pushed.

# From Supabase: Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only secret (never prefixed with NEXT_PUBLIC, never sent to the browser).
# From Supabase: Project Settings -> API -> service_role key
SUPABASE_SERVICE_ROLE_KEY=
